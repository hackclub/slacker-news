---
import BaseLayout from "../layouts/BaseLayout.astro";
import SlackMention from "../components/SlackMention.astro";
import { getChangelogEntries, getSiteConfig } from "../lib/content";

const site = await getSiteConfig();
const changelogEntries = await getChangelogEntries();
---

<BaseLayout title="Changelogs Archive" siteTitle={site.title} siteDescription={site.description}>
  <div class="archive-page">
    <div class="section-header">
      <h1 class="section-label">Changelog</h1>
    </div>
    <hr class="section-rule" />
    <div class="archive-list">
      {changelogEntries.map((entry) => (
        <div class="archive-card">
          <h3 class="archive-card-title">{entry.change}</h3>
          <div class="archive-card-meta">
            {entry.date} · {(() => {
              const authorName = entry.author.trim().replace(/^@+/, "");
              return entry.slackId ? <SlackMention name={authorName} id={entry.slackId} /> : entry.author;
            })()}
          </div>
        </div>
      ))}
    </div>
  </div>
</BaseLayout>
