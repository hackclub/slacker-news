---
import BaseLayout from "../layouts/BaseLayout.astro";
import AuthorList from "../components/AuthorList.astro";
import { getChangelogEntries, getSiteConfig, truncateWords } from "../lib/content";

const site = await getSiteConfig();
const changelogEntries = await getChangelogEntries();
---

<BaseLayout title="Changelogs Archive" siteTitle={site.title} siteDescription={site.description}>
  <div class="archive-page">
    <div class="section-label">CHANGELOG</div>
    <hr class="section-rule" />
    <div class="archive-list">
      {changelogEntries.map((entry) => {
        if (entry.kind === "long") {
          return (
            <div class="front-block story-block story-block--long">
              <h3 class="story-block-title">
                <a href={entry.url} class="story-block-title-link">{entry.title}</a>
              </h3>
              <p class="story-block-excerpt">{truncateWords(entry.excerpt, 18)}</p>
              <span class="story-block-meta">
                {entry.date} &middot; <AuthorList authors={entry.author} slackIds={entry.slackIds} />
              </span>
            </div>
          );
        }

        return (
          <div class="changelog-archive-item">
            <span class="changelog-change">{entry.change}</span>
            <span class="changelog-meta">
              {entry.date} &middot; <AuthorList authors={entry.author} slackIds={entry.slackIds} />
            </span>
          </div>
        );
      })}
    </div>
  </div>
</BaseLayout>

<style>
  .story-block--long {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .story-block-title-link {
    color: inherit;
    text-decoration: none;
  }

  .story-block-title-link:visited {
    color: inherit;
  }

  .story-block-title-link:hover {
    text-decoration: underline;
  }

  .changelog-archive-item {
    display: flex;
    flex-direction: column;
    gap: 3px;
    padding: 8px 0;
    border-bottom: 1px solid #ddd;
  }

  .changelog-archive-item .changelog-change {
    font-size: 1rem;
    font-weight: bold;
    line-height: 1.3;
  }

  .changelog-archive-item .changelog-meta {
    font-size: 0.82rem;
    color: #555;
    letter-spacing: 0.04em;
  }

  .story-block-meta {
    font-size: 0.82rem;
    color: #555;
    letter-spacing: 0.04em;
    line-height: 1.45;
  }

  html.dark .changelog-archive-item {
    border-bottom-color: #444;
  }
</style>
