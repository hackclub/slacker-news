---
import PageLayout from "../layouts/PageLayout.astro";
import { getPageEntry, getSiteConfig } from "../lib/content";

const site = await getSiteConfig();
const page = await getPageEntry("submissions");
const { Content } = await page.render();
---

<PageLayout
  pageTitle={page.data.title ?? "Submission Guidelines"}
  Content={Content}
  siteTitle={site.title}
  siteDescription={site.description}
/>
