---
import BaseLayout from "../layouts/BaseLayout.astro";
import { formatStoryDate, getPosts, getSiteConfig } from "../lib/content";

export async function getStaticPaths() {
  const allPosts = await getPosts();
  return allPosts.map((post) => ({
    params: { slug: post.slug },
    props: { slug: post.slug }
  }));
}

const site = await getSiteConfig();
const { slug } = Astro.props;
const allPosts = await getPosts();
const post = allPosts.find((p) => p.slug === slug);

if (!post) {
  return Astro.redirect("/404");
}

const { Content } = await post.entry.render();

const responseLinks = post.responseTo?.map((slug) => {
  const target = allPosts.find((p) => p.slug === slug);
  return target ? { slug: target.slug, title: target.title, url: target.url } : null;
}).filter(Boolean) ?? [];

const followUpLinks = post.followUpTo?.map((slug) => {
  const target = allPosts.find((p) => p.slug === slug);
  return target ? { slug: target.slug, title: target.title, url: target.url } : null;
}).filter(Boolean) ?? [];
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  siteTitle={site.title}
  siteDescription={site.description}
  openGraphType="article"
  openGraphImage={post.leadingImage?.src}
  openGraphImageAlt={post.leadingImage?.alt}
  articlePublishedTime={new Date(post.date).toISOString()}
>
  <article class="story-page">
    <header class="story-header">
      <h1 class="story-title">{post.title}</h1>
      <div class="story-meta">
        {post.category && <span class="story-category">{post.category.toUpperCase()}</span>}
        {post.author && <span class="story-author">By {post.author}</span>}
        {post.author && " — "}
        <time>{formatStoryDate(new Date(post.date))}</time>
      </div>
      <hr class="story-rule" />
    </header>

    {post.series && (
      <div class="story-series-banner">
        <strong>Part of series:</strong> {post.series.name}
        {post.series.description && ` — ${post.series.description}`}
        {post.series.order && ` (Part ${post.series.order})`}
        {post.seriesPosts && post.seriesPosts.length > 0 && (
          <div class="series-links">
            {post.seriesPosts.map((sp) => (
              <a href={sp.url} class="series-link">{sp.title}</a>
            ))}
          </div>
        )}
      </div>
    )}

    {post.series && (
      <div class="article-graph-container" id="graph-container"
        data-current-slug={post.slug}
        data-series-posts={JSON.stringify(
          [{ slug: post.slug, title: post.title, url: post.url, order: post.series?.order },
           ...(post.seriesPosts?.map(sp => ({
             ...sp,
             order: allPosts.find(p => p.slug === sp.slug)?.series?.order
           })) || [])
          ]
        )}
        data-responses={JSON.stringify(post.responses || [])}
        data-followups={JSON.stringify(post.followUps || [])}
        data-responseto={JSON.stringify(
          post.responseTo?.map(slug => ({
            slug,
            title: allPosts.find(p => p.slug === slug)?.title || slug,
            url: `/${slug}/`
          })) || []
        )}
        data-followupto={JSON.stringify(
          post.followUpTo?.map(slug => ({
            slug,
            title: allPosts.find(p => p.slug === slug)?.title || slug,
            url: `/${slug}/`
          })) || []
        )}
      >
        <svg id="article-graph" viewBox="0 0 800 400" class="article-graph">
          <defs>
            <marker id="arrowhead" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
              <polygon points="0 0, 10 3, 0 6" fill="#666" />
            </marker>
            <marker id="arrowhead-green" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
              <polygon points="0 0, 10 3, 0 6" fill="#27ae60" />
            </marker>
            <marker id="arrowhead-orange" markerWidth="10" markerHeight="10" refX="9" refY="3" orient="auto">
              <polygon points="0 0, 10 3, 0 6" fill="#e67e22" />
            </marker>
          </defs>
        </svg>
      </div>
    )}

    {responseLinks.length > 0 && (
      <div class="story-response-banner">
        <strong>This is a response to:</strong>
        <ul class="response-links">
          {responseLinks.map((link) => (
            <li><a href={link.url}>{link.title}</a></li>
          ))}
        </ul>
      </div>
    )}

    {followUpLinks.length > 0 && (
      <div class="story-followup-banner">
        <strong>This is a follow-up to:</strong>
        <ul class="followup-links">
          {followUpLinks.map((link) => (
            <li><a href={link.url}>{link.title}</a></li>
          ))}
        </ul>
      </div>
    )}

    {post.responses && post.responses.length > 0 && (
      <div class="story-responses-banner">
        <strong>Responses to this piece:</strong>
        <ul class="response-links">
          {post.responses.map((resp) => (
            <li><a href={resp.url}>{resp.title}</a></li>
          ))}
        </ul>
      </div>
    )}

    {post.followUps && post.followUps.length > 0 && (
      <div class="story-followups-banner">
        <strong>Follow-ups to this piece:</strong>
        <ul class="followup-links">
          {post.followUps.map((fu) => (
            <li><a href={fu.url}>{fu.title}</a></li>
          ))}
        </ul>
      </div>
    )}

    <div class="story-body">
      <Content />
    </div>

    <footer class="story-footer">
      <a href="/">&larr; Back to front page</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .story-series-banner,
  .story-response-banner,
  .story-followup-banner,
  .story-responses-banner,
  .story-followups-banner {
    padding: 0.75rem 1rem;
    margin: 1rem 0;
    border-left: 4px solid #ccc;
    background: #f9f9f9;
    font-size: 0.9rem;
  }

  .story-series-banner {
    border-color: #4a90d9;
    background: #f0f7ff;
  }

  .story-response-banner,
  .story-responses-banner {
    border-color: #e67e22;
    background: #fef5e7;
  }

  .story-followup-banner,
  .story-followups-banner {
    border-color: #27ae60;
    background: #eafaf1;
  }

  .series-links,
  .response-links,
  .followup-links {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0 0;
  }

  .series-links li,
  .response-links li,
  .followup-links li {
    display: inline;
    margin-right: 1rem;
  }

  .series-link,
  .response-links a,
  .followup-links a {
    color: inherit;
    text-decoration: underline;
  }

  .article-graph-container {
    margin: 1.5rem 0;
    padding: 1rem;
    background: #f9f9f9;
    border: 1px solid #ddd;
    border-radius: 4px;
  }

  .article-graph {
    width: 100%;
    height: 400px;
    display: block;
  }

  .graph-node {
    cursor: pointer;
  }

  .graph-node rect {
    rx: 4;
    ry: 4;
  }

  .graph-node.current rect {
    stroke-width: 3;
  }

  .graph-node text {
    font-size: 12px;
    fill: #333;
    pointer-events: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const container = document.getElementById('graph-container');
    if (!container) return;

    const currentSlug = container.dataset.currentSlug;
    const seriesPosts = JSON.parse(container.dataset.seriesPosts || '[]');
    const responses = JSON.parse(container.dataset.responses || '[]');
    const followUps = JSON.parse(container.dataset.followups || '[]');
    const responseTo = JSON.parse(container.dataset.responseto || '[]');
    const followUpTo = JSON.parse(container.dataset.followupto || '[]');

    const svg = document.getElementById('article-graph');
    if (!svg) return;

    const svgNS = 'http://www.w3.org/2000/svg';
    const nodeWidth = 140;
    const nodeHeight = 40;
    const xSpacing = 180;

    const allNodes = new Map();
    const edges = [];

    const sortedSeries = seriesPosts
      .filter(function(p) { return p.order; })
      .sort(function(a, b) { return a.order - b.order; });

    sortedSeries.forEach(function(post, i) {
      allNodes.set(post.slug, {
        slug: post.slug,
        title: post.title,
        url: post.url,
        x: 50 + i * xSpacing,
        y: 180,
        type: 'series'
      });
    });

    responseTo.forEach(function(target) {
      const source = allNodes.get(currentSlug);
      const targetNode = allNodes.get(target.slug);
      if (source && targetNode) {
        edges.push({
          from: source,
          to: targetNode,
          type: 'response-to',
          color: '#e67e22'
        });
      }
    });

    responses.forEach(function(resp) {
      const source = allNodes.get(resp.slug);
      const target = allNodes.get(currentSlug);
      if (source && target) {
        edges.push({
          from: source,
          to: target,
          type: 'response',
          color: '#e67e22'
        });
      }
    });

    followUpTo.forEach(function(target) {
      const source = allNodes.get(currentSlug);
      const targetNode = allNodes.get(target.slug);
      if (source && targetNode) {
        edges.push({
          from: source,
          to: targetNode,
          type: 'followup-to',
          color: '#27ae60'
        });
      }
    });

    followUps.forEach(function(fu) {
      const source = allNodes.get(fu.slug);
      const target = allNodes.get(currentSlug);
      if (source && target) {
        edges.push({
          from: source,
          to: target,
          type: 'followup',
          color: '#27ae60'
        });
      }
    });

    edges.forEach(function(edge) {
      const line = document.createElementNS(svgNS, 'line');
      const marker = edge.color === '#e67e22' ? 'url(#arrowhead-orange)' : 'url(#arrowhead-green)';
      line.setAttribute('x1', edge.from.x + nodeWidth / 2);
      line.setAttribute('y1', edge.from.y + nodeHeight / 2);
      line.setAttribute('x2', edge.to.x + nodeWidth / 2);
      line.setAttribute('y2', edge.to.y + nodeHeight / 2);
      line.setAttribute('stroke', edge.color);
      line.setAttribute('stroke-width', '2');
      line.setAttribute('marker-end', marker);
      svg.appendChild(line);
    });

    allNodes.forEach(function(node) {
      const g = document.createElementNS(svgNS, 'g');
      g.setAttribute('class', 'graph-node' + (node.slug === currentSlug ? ' current' : ''));
      g.setAttribute('transform', 'translate(' + node.x + ', ' + node.y + ')');

      const rect = document.createElementNS(svgNS, 'rect');
      rect.setAttribute('width', nodeWidth);
      rect.setAttribute('height', nodeHeight);
      rect.setAttribute('fill', node.slug === currentSlug ? '#4a90d9' : '#fff');
      rect.setAttribute('stroke', node.slug === currentSlug ? '#2c5f8a' : '#4a90d9');
      rect.setAttribute('stroke-width', '2');

      const text = document.createElementNS(svgNS, 'text');
      text.setAttribute('x', nodeWidth / 2);
      text.setAttribute('y', nodeHeight / 2 + 5);
      text.setAttribute('text-anchor', 'middle');
      text.textContent = node.title.length > 20 ? node.title.substring(0, 18) + '...' : node.title;

      g.appendChild(rect);
      g.appendChild(text);

      if (node.slug !== currentSlug) {
        const a = document.createElementNS(svgNS, 'a');
        a.setAttribute('href', node.url);
        a.appendChild(g);
        svg.appendChild(a);
      } else {
        svg.appendChild(g);
      }
    });

    const legend = document.createElementNS(svgNS, 'g');
    legend.setAttribute('transform', 'translate(10, 10)');

    const items = [
      { label: 'Series', color: '#4a90d9' },
      { label: 'Response', color: '#e67e22' },
      { label: 'Follow-up', color: '#27ae60' }
    ];

    items.forEach(function(item, i) {
      const y = i * 20;
      const rect = document.createElementNS(svgNS, 'rect');
      rect.setAttribute('x', '0');
      rect.setAttribute('y', y.toString());
      rect.setAttribute('width', '12');
      rect.setAttribute('height', '12');
      rect.setAttribute('fill', item.color);

      const text = document.createElementNS(svgNS, 'text');
      text.setAttribute('x', '18');
      text.setAttribute('y', (y + 10).toString());
      text.setAttribute('font-size', '11');
      text.textContent = item.label;

      legend.appendChild(rect);
      legend.appendChild(text);
    });

    svg.appendChild(legend);
  });
</script>
