---
import BaseLayout from "../layouts/BaseLayout.astro";
import SlackMention from "../components/SlackMention.astro";
import {
  getAcknowledgements,
  getChangelogEntries,
  getFrontpageData,
  getPosts,
  getSiteConfig,
  truncateWords,
  formatStoryDate
} from "../lib/content";

const site = await getSiteConfig();
const posts = await getPosts();
const frontpage = await getFrontpageData();

const headlineSlug = frontpage.headline?.[0];
const headline = posts.find((post) => post.slug === headlineSlug);

const allOpinion = posts.filter((post) => post.category === "opinion");
const displayOpinion = allOpinion.slice(0, 3);

const allNews = posts.filter((post) => post.category === "news");
const displayNews = allNews.filter((post) => post.slug !== headlineSlug).slice(0, 8);

const allEssays = posts.filter((post) => post.category === "essays");
const displayEssays = allEssays.slice(0, 4);

const sidebarOpinion = allOpinion.filter((post) => !displayOpinion.some((d) => d.slug === post.slug)).slice(0, 5);

const recentChangelog = (await getChangelogEntries()).slice(0, 3);
const acknowledgements = await getAcknowledgements();
---

<BaseLayout siteTitle={site.title} siteDescription={site.description}>
  <div class="newspaper-front">
    <!-- Top fold: Hero + Sidebar -->
    {headline && (
      <section class="hero-section">
        <a href={headline.url} class="hero-main">
          {headline.leadingImage && (
            <div class="hero-image">
              <img
                src={headline.leadingImage.src}
                alt={headline.leadingImage.alt}
                loading="eager"
                decoding="async"
              />
            </div>
          )}
          <span class="hero-badge">Top Story</span>
          <h2 class="hero-title">{headline.title}</h2>
          {!headline.leadingImage && headline.paragraphs.length > 1 ? (
            <>
              <p class="hero-excerpt">{headline.paragraphs[0]}</p>
              <p class="hero-excerpt">{headline.paragraphs[1]}</p>
            </>
          ) : (
            <p class="hero-excerpt">{headline.paragraphs[0] ?? headline.excerpt}</p>
          )}
          <div class="hero-meta">
            {headline.author && <span>By {headline.author}</span>}
            {headline.author && <span> · </span>}
            <time>{formatStoryDate(new Date(headline.date))}</time>
            {headline.category && (
              <>
                <span> · </span>
                <span>{headline.category}</span>
              </>
            )}
          </div>
        </a>

        <div class="hero-sidebar">
          <h3 class="sidebar-label">Opinion</h3>
          {displayOpinion.map((post) => (
            <a href={post.url} class="sidebar-item">
              <h4 class="sidebar-item-title">{post.title}</h4>
              <p class="sidebar-item-excerpt">{truncateWords(post.excerpt, 12)}</p>
              <div class="sidebar-item-meta">
                {post.author && <span>By {post.author}</span>}
                {post.author && <span> · </span>}
                <time>{formatStoryDate(new Date(post.date))}</time>
              </div>
            </a>
          ))}
          {headline.leadingImage && sidebarOpinion.length > 0 && (
            <>
              <hr class="sidebar-divider" />
              {sidebarOpinion.map((post) => (
                <a href={post.url} class="sidebar-item sidebar-item--compact">
                  <h4 class="sidebar-item-title">{post.title}</h4>
                  <div class="sidebar-item-meta">
                    {post.author && <span>By {post.author}</span>}
                    {post.author && <span> · </span>}
                    <time>{formatStoryDate(new Date(post.date))}</time>
                  </div>
                </a>
              ))}
            </>
          )}
        </div>
      </section>
    )}

    <!-- News -->
    {displayNews.length > 0 && (
      <section>
        <div class="section-header">
          <h2 class="section-label">News</h2>
          <a href="/news/" class="section-more">See all &rarr;</a>
        </div>
        <hr class="section-rule" />
        <div class="headline-grid headline-grid--2">
          {displayNews.map((post) => (
            <a href={post.url} class="headline-card">
              <h3 class="headline-card-title">{post.title}</h3>
              <p class="headline-card-excerpt">{truncateWords(post.excerpt, 14)}</p>
              <div class="headline-card-meta">
                {post.author && <span>By {post.author}</span>}
                {post.author && <span> · </span>}
                <time>{formatStoryDate(new Date(post.date))}</time>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Essays -->
    {displayEssays.length > 0 && (
      <section>
        <div class="section-header">
          <h2 class="section-label">Essays</h2>
          <a href="/essays/" class="section-more">See all &rarr;</a>
        </div>
        <hr class="section-rule" />
        <div class="headline-grid headline-grid--2">
          {displayEssays.map((post) => (
            <a href={post.url} class="headline-card">
              <h3 class="headline-card-title">{post.title}</h3>
              <p class="headline-card-excerpt">{truncateWords(post.excerpt, 18)}</p>
              <div class="headline-card-meta">
                {post.author && <span>By {post.author}</span>}
                {post.author && <span> · </span>}
                <time>{formatStoryDate(new Date(post.date))}</time>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Bottom panels: Changelog & Acknowledgements -->
    <div class="two-column">
      <div>
        <div class="section-header">
          <h2 class="section-label">Changelog</h2>
        </div>
        <hr class="section-rule" />
        <div class="changelog-list">
          {recentChangelog.map((entry) => (
            <div class="changelog-item">
              <span class="changelog-change">{entry.change}</span>
              <span class="changelog-meta">
                {entry.date} · {(() => {
                  const authorName = entry.author.trim().replace(/^@+/, "");
                  return entry.slackId ? <SlackMention name={authorName} id={entry.slackId} /> : entry.author;
                })()}
              </span>
            </div>
          ))}
        </div>
      </div>

      <div>
        <div class="section-header">
          <h2 class="section-label">Acknowledgements</h2>
        </div>
        <hr class="section-rule" />
        <div class="acknowledgements-list">
          {acknowledgements.map((person) => {
            const userName = person.name.trim().replace(/^@+/, "");
            return (
              <span class="acknowledgement-name">
                {person.slackId ? <SlackMention name={userName} id={person.slackId} /> : person.name}
              </span>
            );
          })}
        </div>
      </div>
    </div>
  </div>
</BaseLayout>
