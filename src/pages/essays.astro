---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getPosts, getSiteConfig, truncateWords, formatStoryDate } from "../lib/content";

const site = await getSiteConfig();
const essaysPosts = (await getPosts()).filter((post) => post.category === "essays");
---

<BaseLayout title="Essays Archive" siteTitle={site.title} siteDescription={site.description}>
  <div class="archive-page">
    <div class="section-header">
      <h1 class="section-label">Essays</h1>
    </div>
    <hr class="section-rule" />
    <div class="archive-list">
      {essaysPosts.map((post) => (
        <a href={post.url} class="archive-card">
          <h3 class="archive-card-title">{post.title}</h3>
          <p class="archive-card-excerpt">{truncateWords(post.excerpt, 24)}</p>
          <div class="archive-card-meta">
            {post.author && <span>By {post.author}</span>}
            {post.author && <span> · </span>}
            <time>{formatStoryDate(new Date(post.date))}</time>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
