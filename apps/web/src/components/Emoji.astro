---
interface Props {
    name: string;
    src?: string;
}

const { name, src } = Astro.props;
const imgSrc = src ?? `https://cachet.hackclub.com/emojis/${name}/r`;
---

<img src={imgSrc} alt={`:${name}:`} class="emoji" />

<style>
    .emoji {
        height: 1.2em;
        vertical-align: middle;
        display: inline;
    }
</style>
